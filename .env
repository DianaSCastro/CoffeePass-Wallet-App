# ── Google Wallet ──────────────────────────────────────────────────────────────
# 1. Google Cloud Console → IAM → Service Accounts → Create → download JSON key
# 2. Google Pay & Wallet Console (pay.google.com/business/console)
#    → Wallet API → Issuers → Create Issuer → copy the numeric ID

GOOGLE_WALLET_ISSUER_ID=3388000000023145204
GOOGLE_WALLET_CLASS_SUFFIX=LoyaltyChain_v1
GOOGLE_SERVICE_ACCOUNT_FILE=certs/google-service-account.json
# ── Apple Wallet ───────────────────────────────────────────────────────────────
# 1. developer.apple.com → Certificates → Pass Type IDs → Register
#    → e.g. "pass.io.loyaltychain.member"
# 2. Create & download cert → export as .p12
# 3. Split:
#    openssl pkcs12 -in cert.p12 -nocerts -nodes   -out certs/pass.key
#    openssl pkcs12 -in cert.p12 -clcerts -nokeys  -out certs/pass.crt
# 4. Apple WWDR G4:
#    curl -o certs/wwdr.pem https://www.apple.com/certificateauthority/AppleWWDRCAG4.cer
